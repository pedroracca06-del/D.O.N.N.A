# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_ASSISTANT_MODEL=claude-sonnet-4-6

# ── Broker ────────────────────────────────────────────────────
ALPACA_API_KEY=...
ALPACA_SECRET_KEY=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Discord (PRIMARY delivery) ────────────────────────────────
# 1. Create a Discord server
# 2. Go to discord.com/developers → New Application → Bot → Add Bot → copy token
# 3. Enable "Message Content Intent" under Privileged Gateway Intents
# 4. Invite bot to server with permissions: Send Messages, Embed Links, Attach Files
# 5. Right-click each channel → Copy Channel ID (enable Developer Mode first)
#    Settings → Advanced → Developer Mode → ON

DISCORD_BOT_TOKEN=Bot ...

# Channel IDs — all alerts go to DISCORD_CHANNEL_LIVE until specific channels are set
DISCORD_CHANNEL_LIVE=           # #nova-live  (primary — required)
DISCORD_CHANNEL_HEADS_UP=       # #heads-up   (optional — falls back to LIVE)
DISCORD_CHANNEL_MORNING_BRIEF=  # #morning-brief (optional)
DISCORD_CHANNEL_EXECUTION=      # #execution  (optional)
DISCORD_CHANNEL_INVALIDATION=   # #live-alerts (optional)
DISCORD_CHANNEL_NO_TRADE=       # #macro-risk (optional)
DISCORD_CHANNEL_LOGS=           # #logs       (optional)
DISCORD_CHANNEL_SYSTEM_HEALTH=  # #system-health (optional)

# ── Telegram (secondary / fallback) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_MODE=all

# ── Alert engine ──────────────────────────────────────────────
ALERT_SCREENSHOT=true
ALERT_COOLDOWN_MINUTES=15
ALERT_DAILY_MAX=20

# ── Market data ───────────────────────────────────────────────
FINNHUB_API_KEY=...
FMP_API_KEY=...
ALPHA_VANTAGE_API_KEY=...
FOREX_FACTORY_NOTES_URL=...

# ── Feed sync (local monitor → Render replication) ────────────
# NOVA_RENDER_URL:    Base URL of your Render deployment (no trailing slash)
#                     Find it: Render dashboard → service → Settings → URL
# NOVA_INGEST_SECRET: Shared secret for POST /api/feed/ingest
#                     Generate: python -c "import secrets; print(secrets.token_hex(32))"
#                     Set the SAME value here and in Render env vars.
#                     Leave blank to run feed as local-only (no push to Render).
NOVA_RENDER_URL=https://your-app.onrender.com
NOVA_INGEST_SECRET=
